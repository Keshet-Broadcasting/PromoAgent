# ---------------------------------------------------------------------------
# Langfuse observability — get keys from https://cloud.langfuse.com
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://ai-search-keshet.search.windows.net
AZURE_SEARCH_KEY=<your-admin-api-key>
AZURE_SEARCH_INDEX_NAME=tv-promos

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=aistoragekeshet;AccountKey=<your-key>;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=promo-docs-poc
EXCEL_BLOB_NAME=מעקבי פרומו.xlsx

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://azureopenaipilot.openai.azure.com/
AZURE_OPENAI_KEY=<your-api-key>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure OpenAI — Chat (separate deployment)
AZURE_OPENAI_CHAT_ENDPOINT=https://<your-resource>.openai.azure.com/openai/v1/
AZURE_OPENAI_CHAT_KEY=<your-chat-api-key>
AZURE_OPENAI_CHAT_DEPLOYMENT=<deployment-name>

# ---------------------------------------------------------------------------
# Entra ID authentication
# ---------------------------------------------------------------------------
ENTRA_TENANT_ID=94c43ca5-8a89-42a8-b6d6-f1a37cdff68f
ENTRA_API_CLIENT_ID=ef12944c-913a-473c-90db-7428fc3523f5
# Set to false to disable auth in local development
AUTH_ENABLED=true

# API server
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated allowed origins.
# Use * for local development only.
# For SharePoint: set to your tenant domain(s), e.g.
#   CORS_ORIGINS=https://yourtenant.sharepoint.com,https://yourtenant-admin.sharepoint.com
CORS_ORIGINS=*

# Environment — controls docs visibility and CORS warnings
# dev | staging | production
ENVIRONMENT=dev

# Debug trace — when false, the debug field in /query requests is ignored
ALLOW_DEBUG=false

# Rate limiting — requests per time window per IP
RATE_LIMIT=10/minute

# LLM timeout in seconds
LLM_TIMEOUT_SECONDS=60

# ---------------------------------------------------------------------------
# Chat provider selection
# ---------------------------------------------------------------------------
# azure_openai  (default) — uses openai SDK + API key (current path)
# foundry       — uses Microsoft Agent Framework + Azure credential
CHAT_PROVIDER=azure_openai

# Azure credential type used by the Foundry provider
# cli               → AzureCliCredential (requires: az login)
# managed_identity  → ManagedIdentityCredential (Azure-hosted deployments)
AZURE_CREDENTIAL_TYPE=cli

# Microsoft Foundry — required when CHAT_PROVIDER=foundry
# Agent Framework canonical env var names (also accepted as FOUNDRY_* aliases below)
AZURE_AI_PROJECT_ENDPOINT=https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_MODEL_DEPLOYMENT_NAME=<deployment-name>
# FOUNDRY_PROJECT_ENDPOINT=     (alias for AZURE_AI_PROJECT_ENDPOINT)
# FOUNDRY_MODEL_DEPLOYMENT_NAME=(alias for AZURE_AI_MODEL_DEPLOYMENT_NAME)

# ---------------------------------------------------------------------------
# SharePoint fallback (complementary knowledge source — optional)
# When primary Azure AI Search returns no results, the agent searches this
# SharePoint document library using the SharePoint REST Search API.
# Auth reuses AZURE_CREDENTIAL_TYPE (same credential as the Foundry provider).
# No Entra app registration or client secret needed.
#   Local dev:  az login  then  AZURE_CREDENTIAL_TYPE=cli
#   Azure prod: AZURE_CREDENTIAL_TYPE=managed_identity
# ---------------------------------------------------------------------------
# Site URL — do NOT include the library name here
SP_SITE_URL=https://keshettv.sharepoint.com/sites/Promo
# Document library name (the folder in the site)
SP_DOC_LIBRARY=DocLib4
# Enrichment feature flag — disabled by default; enable after verifying SP auth works
SP_ENRICHMENT_ENABLED=false
# Trigger threshold: Azure semantic reranker is 0–4 scale (2.3–2.5 = typical confident result)
# Fire SP enrichment when word-doc top score is below this value
SP_SCORE_THRESHOLD=2.5
# Max number of SP documents to append to the context per query
SP_ENRICHMENT_TOP=3

# ---------------------------------------------------------------------------
# Pipeline publishing (only needed for pipeline/publish.py)
# ---------------------------------------------------------------------------
# AZURE_SUBSCRIPTION_ID=<your-subscription-id>
# AZURE_RESOURCE_GROUP=<your-resource-group>
# AZURE_ACCOUNT_NAME=Keshet-Foundry        (auto-derived from endpoint if omitted)
# AZURE_PROJECT_NAME=Keshet-AI-Foundry     (auto-derived from endpoint if omitted)